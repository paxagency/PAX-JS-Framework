  "license": "MIT",
  "author": "PAX Agency <hello@paxagency.com>",
  "description": "PAX JS Framework — minimal, HTML-first JavaScript framework with binding, routing, and ajax. No build step.",
  "main": "dist/pax.js",
  "module": "dist/pax.esm.js",
  "types": "pax.d.ts",
  "files": [
    "dist/pax.js",
    "dist/pax.min.js",
    "dist/pax.esm.js",
    "dist/pax.esm.min.js",
    "pax.d.ts",
    "index.html",
    "docs/example-sources.js",
    "examples",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "test": "npm run build && node --test test/pax.test.js",
    "docs:sources": "node scripts/generate-example-sources.js",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paxagency/PAX-JS-Framework.git"
  },
  "keywords": [
    "javascript",
    "minimal",
    "html-first",
    "binding",
    "router",
    "framework",
    "no-build"
  ],
  "bugs": {
    "url": "https://github.com/paxagency/PAX-JS-Framework/issues"
  },
  "devDependencies": {
    "happy-dom": "^20.8.9",
    "terser": "^5.39.0"
  }
}
